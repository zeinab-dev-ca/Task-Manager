@model IEnumerable<TaskManager.Models.TaskItem>

@{
    ViewData["Title"] = "My Tasks";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2 class="mb-1"><i class="fas fa-tasks me-2"></i>My Tasks</h2>
            <p class="mb-0 opacity-75">Manage your tasks with AI-powered priority suggestions</p>
        </div>
        <a href="/TaskItems/Create" class="btn btn-light btn-lg">
            <i class="fas fa-plus me-2"></i>New Task
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Due Date</th>
                    <th>Priority</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">@item.Title</td>
                        <td class="text-muted">@item.Description</td>
                        <td>@item.DueDate.ToString("MMM dd, yyyy")</td>
                        <td>
                            @if (item.Priority == "High")
                            {
                                <span class="badge-high">🔴 High</span>
                            }
                            else if (item.Priority == "Medium")
                            {
                                <span class="badge-medium">🟠 Medium</span>
                            }
                            else
                            {
                                <span class="badge-low">🟢 Low</span>
                            }
                        </td>
                        <td>
                            @if (item.IsCompleted)
                            {
                                <span class="badge bg-success">✅ Done</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">⏳ Pending</span>
                            }
                        </td>
                        <td>
                            <a href="/TaskItems/Edit/@item.Id" class="btn btn-sm btn-primary me-1">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a href="/TaskItems/Details/@item.Id" class="btn btn-sm btn-outline-secondary me-1">
                                <i class="fas fa-eye"></i>
                            </a>
                            <a href="/TaskItems/Delete/@item.Id" class="btn btn-sm btn-danger">
                                <i class="fas fa-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-clipboard fa-3x mb-3"></i>
                <p>No tasks yet. Click <a href="/TaskItems/Create">New Task</a> to get started!</p>
            </div>
        }
    </div>
</div>